<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.yjp.onlyone.presentation.splash.SplashFragment"
        android:label="@string/splash_title">
        <action
            android:id="@+id/action_splash_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.yjp.onlyone.presentation.home.HomeFragment"
        android:label="@string/home_title">
        <action
            android:id="@+id/action_home_to_memo"
            app:destination="@id/memoFragment" />
        <action
            android:id="@+id/action_home_to_dog_info_edit"
            app:destination="@id/dogInfoEditFragment" />
    </fragment>

    <fragment
        android:id="@+id/dogInfoEditFragment"
        android:name="com.yjp.onlyone.presentation.doginfoedit.DogInfoEditFragment"
        android:label="@string/dog_info_edit_title" />

    <fragment
        android:id="@+id/memoFragment"
        android:name="com.yjp.onlyone.presentation.memo.MemoFragment"
        android:label="@string/memo_title">
        <action
            android:id="@+id/action_memo_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/memoFragment"
            app:popUpToInclusive="true" />
    </fragment>
</navigation>
